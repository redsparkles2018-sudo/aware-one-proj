{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/source/layout,_N_T_/services/source/page,_N_T_/services/source"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/source/__PAGE__",
    "/services/source",
    "/services",
    "/_index",
    "/_head"
  ]
}