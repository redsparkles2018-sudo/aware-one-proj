{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/build/layout,_N_T_/services/build/page,_N_T_/services/build"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/build/__PAGE__",
    "/services/build",
    "/services",
    "/_index",
    "/_head"
  ]
}