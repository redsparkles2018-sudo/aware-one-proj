{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/operate/layout,_N_T_/services/operate/page,_N_T_/services/operate"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/operate/__PAGE__",
    "/services/operate",
    "/services",
    "/_index",
    "/_head"
  ]
}